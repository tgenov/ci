{
	"compilerOptions": {
		"target": "ES2019",
		"module": "commonjs",
		"lib": ["ES2019"],
		"outDir": "./lib",
		"rootDir": "./src",
		"strict": true,
		"useUnknownInCatchVariables": false,
		"noImplicitAny": true,
		"esModuleInterop": true,
		"moduleResolution": "node",
		"sourceMap": true,
		"declaration": true,
		"composite": true
	},
	"exclude": ["node_modules", "dist", "__tests__"],
	"references": [
		{
			"path": "../common"
		}
	]
}
