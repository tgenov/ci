{
  "name": "devcontainer-merge-task",
  "version": "0.0.0",
  "private": true,
  "description": "Azure DevOps task for merging multi-platform Dev Container images into a multi-arch manifest",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc --build",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "package": "ncc build --source-map --license licenses.txt",
    "all": "npm run build && npm run format && npm run lint && npm run package"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devcontainers/ci.git"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.9.0",
    "@types/q": "^1.5.8",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vercel/ncc": "^0.38.4",
    "azure-pipelines-task-lib": "^5.2.1",
    "eslint": "^8.57.0",
    "eslint-plugin-github": "^5.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
